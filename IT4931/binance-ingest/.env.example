# Environment
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000

# Kafka Configuration
KAFKA_BROKER=kafka:29092
KAFKA_GROUP_ID=binance-ingest-group
KAFKA_TOPIC_PRICES=crypto-prices
KAFKA_TOPIC_OHLC=crypto-ohlc

# Elasticsearch Configuration
ELASTICSEARCH_NODE=http://elasticsearch:9200
ELASTICSEARCH_INDEX_PREFIX=binance

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Binance Configuration
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT

# Application Configuration
APP_NAME=binance-ingest
AGGREGATION_WINDOW_MS=60000
